GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/callback
PORT=5000
FRONTEND_URL=http://localhost:3000

# Supabase — get these from: https://supabase.com/dashboard → project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Column-level encryption (AES-256-GCM). 32 bytes as 64 hex chars.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# OCR pipeline
# OCR_ENGINE: "docling" (default, layout-aware), "auto" (Docling + GOT-OCR fallback for math), "tesseract" (legacy)
OCR_ENGINE=docling
# GOT_OCR_ENABLED: gates loading of GOT-OCR 2.0 weights. Requires GPU in practice; keep false on CPU-only deployments.
GOT_OCR_ENABLED=false
# HuggingFace repo id or local path for GOT-OCR 2.0 weights. Note: model uses trust_remote_code=True.
GOT_OCR_MODEL_PATH=stepfun-ai/GOT-OCR2_0
