{
  "name": "sapling-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && wrangler dev -c wrangler.workers.toml",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy -c wrangler.workers.toml"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "d3": "^7.9.0",
    "katex": "^0.16.45",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5",
    "wrangler": "^4.83.0"
  }
}
