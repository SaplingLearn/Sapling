# Cloudflare Workers Builds runs `npm clean-install` with npm 10.9.2 in
# strict mode. If a contributor on npm 11+ regenerates the lockfile, the
# resulting v3 lockfile fails CF's `npm ci` ("Missing X from lock file").
# `engine-strict=true` makes local installs fail fast against the
# package.json `engines` constraint instead of silently producing a
# broken lockfile. Pin matches package.json: node >=20.9.0, npm 10.9.x.
engine-strict=true
