# Set to "true" for mock-data dev mode (no backend required).
NEXT_PUBLIC_LOCAL_MODE=false

# Backend URL consumed by client fetches. Leave empty in production so
# calls resolve as same-origin /api/... paths, which Next.js rewrites
# to BACKEND_URL server-side. Only set this if the frontend runs on a
# different origin than the proxy and CORS is configured on the backend.
NEXT_PUBLIC_API_URL=

# Backend URL for the Next.js rewrite (/api/:path* -> ${BACKEND_URL}/api/:path*).
# Required in production. Locally this defaults to http://localhost:5000.
BACKEND_URL=http://localhost:5000

# HMAC secret (min 32 bytes). Must match backend SESSION_SECRET.
SESSION_SECRET=replace-me-with-at-least-32-bytes-of-random-string

# Supabase (for realtime chat in /social rooms).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
